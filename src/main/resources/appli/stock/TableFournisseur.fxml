<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.controller.stock.TableFournisseurController">
    <HBox AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" spacing="15">
        <!-- Tableau à gauche -->
        <TableView fx:id="tableauFournisseur" HBox.hgrow="ALWAYS" />

        <!-- Panneau droit -->
        <VBox spacing="20" prefWidth="280" minWidth="280">
            <padding><Insets top="5" right="5" bottom="5" left="5" /></padding>

            <!-- Section : Ajouter un fournisseur -->
            <Label text="Ajouter un fournisseur" style="-fx-font-size: 14; -fx-font-weight: bold;" />

            <VBox spacing="8">
                <Label text="Nom" />
                <TextField fx:id="fieldNom" promptText="Nom du fournisseur" />

                <Label text="Email" />
                <TextField fx:id="fieldEmail" promptText="Email du fournisseur" />

                <Label text="Téléphone" />
                <TextField fx:id="fieldTel" promptText="Téléphone du fournisseur" />

                <Button fx:id="btnAjouter" text="Ajouter" onAction="#onAjouterFournisseur" maxWidth="Infinity"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            </VBox>

            <Separator />

            <!-- Section : Supprimer un fournisseur -->
            <Label text="Supprimer un fournisseur" style="-fx-font-size: 14; -fx-font-weight: bold;" />

            <VBox spacing="8">
                <Label text="Sélectionnez un fournisseur dans le tableau" style="-fx-font-style: italic; -fx-text-fill: grey;" />

                <Label fx:id="labelFournisseurSelectionne" text="Aucun fournisseur sélectionné" />

                <Button fx:id="btnSupprimer" text="Supprimer" onAction="#onSupprimerFournisseur" maxWidth="Infinity"
                        style="-fx-background-color: #F44336; -fx-text-fill: white;" />
            </VBox>
        </VBox>
    </HBox>
</AnchorPane>
