<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.controller.stock.TableProduitFournisseurController">
    <HBox AnchorPane.topAnchor="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" spacing="15">
        <TableView fx:id="tableauProduitFournisseur" HBox.hgrow="ALWAYS" />

        <VBox spacing="20" prefWidth="280" minWidth="280">
            <padding><Insets top="5" right="5" bottom="5" left="5" /></padding>

            <Label text="Lier un produit à un fournisseur" style="-fx-font-size: 14; -fx-font-weight: bold;" />

            <VBox spacing="8">
                <Label text="Produit" />
                <ComboBox fx:id="comboProduit" promptText="Choisir un produit" maxWidth="Infinity" />

                <Label text="Fournisseur" />
                <ComboBox fx:id="comboFournisseur" promptText="Choisir un fournisseur" maxWidth="Infinity" />

                <Label text="Prix" />
                <Spinner fx:id="spinnerPrix" editable="true" maxWidth="Infinity" />

                <Button fx:id="btnAjouter" text="Ajouter" onAction="#onAjouterProduitFournisseur" maxWidth="Infinity"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
            </VBox>
        </VBox>
    </HBox>
</AnchorPane>
