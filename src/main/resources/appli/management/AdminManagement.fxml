<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.controller.main.AdminController"
            prefWidth="900" prefHeight="600">

    <!-- Menu gauche combiné -->
    <left>
        <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #2c3e50;">

            <!-- Médecin -->
            <Label text="Médecin" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Dossier des patients" onAction="#onDossierMedecin"/>
            <Button text="Demande de stock" onAction="#onDemandeDeStock"/>
            <Button text="Hospitalisation" onAction="#onHospitalisation"/>
            <Button text="Ordonnance" onAction="#onOrdonnance"/>

            <!-- Secrétariat -->
            <Label text="Secrétariat" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Fiches Patients" onAction="#onFichesPatients"/>
            <Button text="Dossiers" onAction="#onDossierSecretaire"/>

            <!-- Stock -->
            <Label text="Stock" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Liste Stock" onAction="#onListeStock"/>
            <Button text="Validation/Refus" onAction="#onValidRefus"/>
            <Button text="Fournisseur" onAction="#onFournisseur"/>
        </VBox>
    </left>

    <!-- Zone centrale avec StackPane pour chaque vue -->
    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #ecf0f1; -fx-padding: 15;">
            <!-- Les sous-vues Médecin, Secrétariat, Stock seront injectées ici -->
        </StackPane>
    </center>

    <!-- Zone droite (optionnelle, pour Médecin et Secrétariat) -->
    <right>
        <AnchorPane fx:id="testDroite"/>
    </right>

    <!-- Bas : label utilisateur connecté -->
    <bottom>
        <HBox style="-fx-padding: 10; -fx-background-color: #bdc3c7;">
            <Label text="Connecté : "/>
            <Label fx:id="userLabel" text="Invité"/>
        </HBox>
    </bottom>

</BorderPane>