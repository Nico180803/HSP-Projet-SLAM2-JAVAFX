<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="appli.controller.HistoriqueConnexionController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="531.0" prefWidth="126.0" spacing="20" style="-fx-background-color: #2c3e50; -fx-padding: 20;">

            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Admin" />
         <Button onAction="#onHistoriqueConnexion" text="Historique" />
         <Button onAction="#onHistoriqueConnexion" text="Retour" />

        </VBox>
    </left>

    <!-- Contenu -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- Barre d’action -->
            <HBox spacing="10">
                <TextField fx:id="searchField" prefWidth="250" promptText="Rechercher un utilisateur..." />
            <Button onAction="#onHistoriqueConnexion" text="Rechercher" />
            <Button onAction="#onHistoriqueConnexion" text="Actualiser" />
            </HBox>

            <!-- Table -->
            <TableView fx:id="tableHistorique" prefHeight="450">

                <columns>
                    <TableColumn fx:id="colDate" prefWidth="150" text="Date / Heure" />

                    <TableColumn fx:id="colUtilisateur" prefWidth="150" text="Utilisateur" />

                    <TableColumn fx:id="colAction" prefWidth="120" text="Action" />

                    <TableColumn fx:id="colDescription" prefWidth="350" text="Description" />
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
